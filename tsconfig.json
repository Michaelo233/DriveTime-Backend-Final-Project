{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ES6",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": ".",
        "resolveJsonModule": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "alwaysStrict": true,
        "baseUrl": "./",
        "paths": {
            "*": ["*"]
        },
        "types": ["jest", "node"]
    },
    "include": ["src/**/*", "src/config/**/*", "src/config", "test/**/*", "scripts/**/*"],
    "exclude": ["node_modules", "dist"]
}